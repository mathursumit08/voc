{
  "name": "voc",
  "version": "0.1.0",
  "private": true,
  "description": "Voice of Customer prototype module.",
  "workspaces": [
    "src/backend",
    "src/frontend",
    "src/shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @voc/backend",
    "dev:backend": "npm run dev --workspace @voc/backend",
    "dev:frontend": "npm run dev --workspace @voc/frontend",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "seed:prototype": "npm run seed:prototype --workspace @voc/backend"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

