NODE_ENV=development
APP_NAME=VoC Prototype
API_HOST=localhost
API_PORT=4000
API_VERSION=v1
DATABASE_URL=postgresql://postgres:Vectordbm1@localhost:5432/voc
POSTGRES_DB=voc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Vectordbm1
SWAGGER_TITLE=VoC Prototype API
SWAGGER_VERSION=1.0.0
RUN_MIGRATIONS_ON_START=true
MIGRATIONS_DIR=src/backend/data/migrations
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
