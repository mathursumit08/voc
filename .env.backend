WARRANTY_SIGNAL_MIN_SUPPORTING_COUNT=2
JWT_ACCESS_SECRET=local-dev-access-secret-min-16
JWT_REFRESH_SECRET=local-dev-refresh-secret-min-16
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=86400
