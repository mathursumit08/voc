NODE_ENV=development
APP_NAME=VoC Prototype
API_HOST=0.0.0.0
API_PORT=4000
API_VERSION=v1
DATABASE_URL=postgresql://voc_user:voc_password@postgres:5432/voc
POSTGRES_DB=voc
POSTGRES_USER=voc_user
POSTGRES_PASSWORD=voc_password
SWAGGER_TITLE=VoC Prototype API
SWAGGER_VERSION=1.0.0
RUN_MIGRATIONS_ON_START=true
MIGRATIONS_DIR=src/backend/data/migrations
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
REPEAT_COMPLAINT_LOOKBACK_DAYS=90
WARRANTY_SIGNAL_LOOKBACK_DAYS=180
WARRANTY_SIGNAL_MIN_SUPPORTING_COUNT=2
JWT_ACCESS_SECRET=change-me-access-secret-min-16
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=86400
