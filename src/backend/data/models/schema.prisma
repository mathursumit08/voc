generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FeedbackSourceType {
  Survey
  JobCard
  WarrantyClaim
  GoogleReview
  SocialMedia
  CallCenter
  MobileApp
  ManualUpload
}

enum ProcessingStatus {
  Pending
  Processing
  Completed
  Failed
  NeedsReview
}

enum SentimentLabel {
  Positive
  Neutral
  Negative
  Mixed
  Unknown
}

enum IssueCategory {
  ServiceQuality
  RepairQuality
  StaffBehavior
  PriceTransparency
  PartsAvailability
  WarrantyConcern
  VehicleQuality
  DeliveryDelay
  FacilityExperience
  DigitalExperience
  Other
}

enum UrgencyLevel {
  Low
  Medium
  High
  Critical
}

enum ChurnRiskLevel {
  Low
  Medium
  High
  Critical
}

enum SignalStatus {
  Open
  UnderReview
  Escalated
  Closed
}

enum CrmTaskStatus {
  Open
  InProgress
  Closed
  Cancelled
}

enum ReviewQueueStatus {
  Open
  InReview
  Resolved
  Dismissed
}

enum UserRole {
  Admin
  OemUser
  DealerUser
  Reviewer
}

model Customer {
  id               String           @id @default(uuid()) @db.Uuid
  externalId       String?          @unique @map("external_id")
  maskedName       String?          @map("masked_name")
  maskedPhone      String?          @map("masked_phone")
  maskedEmail      String?          @map("masked_email")
  city             String?
  state            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  vehicles         Vehicle[]
  feedbackRecords  FeedbackRecord[]
  churnScores      ChurnScore[]
  crmTasks         CrmTask[]
  jobCards         JobCard[]
  warrantyClaims   WarrantyClaim[]
  repeatSignals    RepeatComplaintSignal[]

  @@index([state, city])
  @@map("customers")
}

model Vehicle {
  id              String           @id @default(uuid()) @db.Uuid
  customerId      String           @map("customer_id") @db.Uuid
  vinHash         String?          @unique @map("vin_hash")
  registrationNo  String?          @map("registration_no")
  model           String
  variant         String?
  modelYear       Int?             @map("model_year")
  purchaseDate    DateTime?        @map("purchase_date")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  customer        Customer         @relation(fields: [customerId], references: [id])
  jobCards        JobCard[]
  warrantyClaims  WarrantyClaim[]
  feedbackRecords FeedbackRecord[]
  churnScores     ChurnScore[]
  repeatSignals   RepeatComplaintSignal[]

  @@index([customerId])
  @@index([model, variant])
  @@index([purchaseDate])
  @@map("vehicles")
}

model Dealer {
  id              String           @id @default(uuid()) @db.Uuid
  externalId      String?          @unique @map("external_id")
  name            String
  code            String           @unique
  region          String
  city            String
  state           String
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  jobCards        JobCard[]
  warrantyClaims  WarrantyClaim[]
  feedbackRecords FeedbackRecord[]
  dealerScores    DealerScore[]
  warrantySignals WarrantySignal[]
  crmTasks        CrmTask[]
  users           AppUser[]

  @@index([region])
  @@index([state, city])
  @@index([isActive])
  @@map("dealers")
}

model AppUser {
  id           String    @id @default(uuid()) @db.Uuid
  username     String    @unique
  displayName  String    @map("display_name")
  role         UserRole
  dealerId     String?   @map("dealer_id") @db.Uuid
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  dealer       Dealer?   @relation(fields: [dealerId], references: [id])

  @@index([role, isActive])
  @@index([dealerId])
  @@map("app_users")
}

model JobCard {
  id              String           @id @default(uuid()) @db.Uuid
  externalId      String           @unique @map("external_id")
  customerId      String?          @map("customer_id") @db.Uuid
  vehicleId       String           @map("vehicle_id") @db.Uuid
  dealerId        String           @map("dealer_id") @db.Uuid
  openedAt        DateTime         @map("opened_at")
  closedAt        DateTime?        @map("closed_at")
  serviceType     String?          @map("service_type")
  technicianNotes String?          @map("technician_notes")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id])
  dealer          Dealer           @relation(fields: [dealerId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  feedbackRecords FeedbackRecord[]

  @@index([customerId, openedAt])
  @@index([vehicleId, openedAt])
  @@index([dealerId, openedAt])
  @@index([closedAt])
  @@map("job_cards")
}

model WarrantyClaim {
  id              String           @id @default(uuid()) @db.Uuid
  externalId      String           @unique @map("external_id")
  customerId      String?          @map("customer_id") @db.Uuid
  vehicleId       String           @map("vehicle_id") @db.Uuid
  dealerId        String           @map("dealer_id") @db.Uuid
  claimDate       DateTime         @map("claim_date")
  partCode        String?          @map("part_code")
  partName        String?          @map("part_name")
  claimCategory   String?          @map("claim_category")
  description     String?
  amount          Decimal?         @db.Decimal(12, 2)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id])
  dealer          Dealer           @relation(fields: [dealerId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  feedbackRecords FeedbackRecord[]
  warrantySignals WarrantySignal[]

  @@index([customerId, claimDate])
  @@index([vehicleId, claimDate])
  @@index([dealerId, claimDate])
  @@index([partCode])
  @@index([claimCategory])
  @@map("warranty_claims")
}

model FeedbackRecord {
  id                   String                @id @default(uuid()) @db.Uuid
  sourceType           FeedbackSourceType    @map("source_type")
  sourceReferenceId    String                @map("source_reference_id")
  customerId           String?               @map("customer_id") @db.Uuid
  vehicleId            String?               @map("vehicle_id") @db.Uuid
  dealerId             String?               @map("dealer_id") @db.Uuid
  jobCardId            String?               @map("job_card_id") @db.Uuid
  warrantyClaimId      String?               @map("warranty_claim_id") @db.Uuid
  feedbackDate         DateTime              @map("feedback_date")
  rawText              String                @map("raw_text")
  maskedText           String?               @map("masked_text")
  rating               Int?
  processingStatus     ProcessingStatus      @default(Pending) @map("processing_status")
  processingError      String?               @map("processing_error")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  customer             Customer?             @relation(fields: [customerId], references: [id])
  vehicle              Vehicle?              @relation(fields: [vehicleId], references: [id])
  dealer               Dealer?               @relation(fields: [dealerId], references: [id])
  jobCard              JobCard?              @relation(fields: [jobCardId], references: [id])
  warrantyClaim        WarrantyClaim?        @relation(fields: [warrantyClaimId], references: [id])
  nlpResult            NlpResult?
  issueClassifications IssueClassification[]
  churnScores          ChurnScore[]
  warrantySignals      WarrantySignal[]
  crmTasks             CrmTask[]
  reviewItems          HumanReviewQueue[]
  repeatComplaintSignal RepeatComplaintSignal?

  @@unique([sourceType, sourceReferenceId])
  @@index([processingStatus, feedbackDate])
  @@index([sourceType, feedbackDate])
  @@index([dealerId, feedbackDate])
  @@index([customerId, feedbackDate])
  @@index([vehicleId, feedbackDate])
  @@index([jobCardId])
  @@index([warrantyClaimId])
  @@map("feedback_records")
}

model RepeatComplaintSignal {
  id                        String         @id @default(uuid()) @db.Uuid
  feedbackRecordId          String         @unique @map("feedback_record_id") @db.Uuid
  customerId                String?        @map("customer_id") @db.Uuid
  vehicleId                 String?        @map("vehicle_id") @db.Uuid
  lookbackDays              Int            @map("lookback_days")
  repeatCount               Int            @default(0) @map("repeat_count")
  matchingFeedbackRecordIds String[]       @map("matching_feedback_record_ids") @db.Uuid
  isRepeat                  Boolean        @default(false) @map("is_repeat")
  reasonSummary             String?        @map("reason_summary")
  detectedAt                DateTime       @default(now()) @map("detected_at")
  createdAt                 DateTime       @default(now()) @map("created_at")
  updatedAt                 DateTime       @updatedAt @map("updated_at")
  feedbackRecord            FeedbackRecord @relation(fields: [feedbackRecordId], references: [id])
  customer                  Customer?      @relation(fields: [customerId], references: [id])
  vehicle                   Vehicle?       @relation(fields: [vehicleId], references: [id])

  @@index([customerId, detectedAt])
  @@index([vehicleId, detectedAt])
  @@index([isRepeat, detectedAt])
  @@index([repeatCount])
  @@map("repeat_complaint_signals")
}

model NlpResult {
  id                 String          @id @default(uuid()) @db.Uuid
  feedbackRecordId   String          @unique @map("feedback_record_id") @db.Uuid
  detectedLanguage   String          @map("detected_language")
  translatedText     String?         @map("translated_text")
  sentimentLabel     SentimentLabel  @default(Unknown) @map("sentiment_label")
  sentimentScore     Decimal?        @map("sentiment_score") @db.Decimal(5, 4)
  topics             String[]
  entities           Json?
  modelName          String?         @map("model_name")
  modelVersion       String?         @map("model_version")
  confidenceScore    Decimal?        @map("confidence_score") @db.Decimal(5, 4)
  processedAt        DateTime        @default(now()) @map("processed_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  feedbackRecord     FeedbackRecord  @relation(fields: [feedbackRecordId], references: [id])

  @@index([sentimentLabel])
  @@index([detectedLanguage])
  @@index([processedAt])
  @@map("nlp_results")
}

model IssueClassification {
  id               String          @id @default(uuid()) @db.Uuid
  feedbackRecordId String          @map("feedback_record_id") @db.Uuid
  category         IssueCategory
  subCategory      String?         @map("sub_category")
  urgencyLevel     UrgencyLevel    @default(Low) @map("urgency_level")
  confidenceScore  Decimal?        @map("confidence_score") @db.Decimal(5, 4)
  explanation      String?
  isPrimary        Boolean         @default(false) @map("is_primary")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  feedbackRecord   FeedbackRecord  @relation(fields: [feedbackRecordId], references: [id])

  @@index([feedbackRecordId])
  @@index([category, urgencyLevel])
  @@index([urgencyLevel])
  @@map("issue_classifications")
}

model ChurnScore {
  id               String          @id @default(uuid()) @db.Uuid
  customerId       String          @map("customer_id") @db.Uuid
  vehicleId        String?         @map("vehicle_id") @db.Uuid
  feedbackRecordId String?         @map("feedback_record_id") @db.Uuid
  score            Decimal         @db.Decimal(5, 2)
  riskLevel        ChurnRiskLevel  @map("risk_level")
  reasonSummary    String?         @map("reason_summary")
  scoredAt         DateTime        @default(now()) @map("scored_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  customer         Customer        @relation(fields: [customerId], references: [id])
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id])
  feedbackRecord   FeedbackRecord? @relation(fields: [feedbackRecordId], references: [id])

  @@index([customerId, scoredAt])
  @@index([vehicleId, scoredAt])
  @@index([riskLevel, scoredAt])
  @@map("churn_scores")
}

model DealerScore {
  id                String   @id @default(uuid()) @db.Uuid
  dealerId          String   @map("dealer_id") @db.Uuid
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  csiScore          Decimal? @map("csi_score") @db.Decimal(6, 2)
  npsScore          Decimal? @map("nps_score") @db.Decimal(6, 2)
  sentimentScore    Decimal? @map("sentiment_score") @db.Decimal(5, 4)
  retentionRate     Decimal? @map("retention_rate") @db.Decimal(5, 4)
  openEscalations   Int      @default(0) @map("open_escalations")
  feedbackCount     Int      @default(0) @map("feedback_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  dealer            Dealer   @relation(fields: [dealerId], references: [id])

  @@unique([dealerId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
  @@index([csiScore])
  @@index([npsScore])
  @@map("dealer_scores")
}

model WarrantySignal {
  id                  String           @id @default(uuid()) @db.Uuid
  dealerId            String?          @map("dealer_id") @db.Uuid
  warrantyClaimId     String?          @map("warranty_claim_id") @db.Uuid
  feedbackRecordId    String?          @map("feedback_record_id") @db.Uuid
  model               String?
  partCode            String?          @map("part_code")
  issueCategory       IssueCategory?   @map("issue_category")
  signalScore         Decimal?         @map("signal_score") @db.Decimal(5, 2)
  status              SignalStatus     @default(Open)
  supportingCount     Int              @default(0) @map("supporting_count")
  summary             String?
  detectedAt          DateTime         @default(now()) @map("detected_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  dealer              Dealer?          @relation(fields: [dealerId], references: [id])
  warrantyClaim       WarrantyClaim?   @relation(fields: [warrantyClaimId], references: [id])
  feedbackRecord      FeedbackRecord?  @relation(fields: [feedbackRecordId], references: [id])

  @@index([status, detectedAt])
  @@index([model, partCode])
  @@index([dealerId, detectedAt])
  @@index([issueCategory])
  @@map("warranty_signals")
}

model CrmTask {
  id               String          @id @default(uuid()) @db.Uuid
  feedbackRecordId String          @map("feedback_record_id") @db.Uuid
  customerId       String?         @map("customer_id") @db.Uuid
  dealerId         String?         @map("dealer_id") @db.Uuid
  title            String
  description      String?
  priority         UrgencyLevel    @default(Medium)
  status           CrmTaskStatus   @default(Open)
  dueAt            DateTime?       @map("due_at")
  closedAt         DateTime?       @map("closed_at")
  resolutionNotes  String?         @map("resolution_notes")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  feedbackRecord   FeedbackRecord  @relation(fields: [feedbackRecordId], references: [id])
  customer         Customer?       @relation(fields: [customerId], references: [id])
  dealer           Dealer?         @relation(fields: [dealerId], references: [id])

  @@index([status, dueAt])
  @@index([priority, status])
  @@index([dealerId, status])
  @@index([customerId])
  @@map("crm_tasks")
}

model HumanReviewQueue {
  id               String            @id @default(uuid()) @db.Uuid
  feedbackRecordId String            @map("feedback_record_id") @db.Uuid
  status           ReviewQueueStatus @default(Open)
  reason           String
  assignedTo       String?           @map("assigned_to")
  reviewerNotes    String?           @map("reviewer_notes")
  resolvedAt       DateTime?         @map("resolved_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  feedbackRecord   FeedbackRecord    @relation(fields: [feedbackRecordId], references: [id])

  @@index([status, createdAt])
  @@index([assignedTo, status])
  @@index([feedbackRecordId])
  @@map("human_review_queue")
}
